# =====================================================================
# Lumi — environment template
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored, never commit secrets.
# =====================================================================

# ----- Frontend (Vite — only VITE_* vars are exposed to the browser) -----
# These are public values that go in the payment URL. Safe to expose.
VITE_NOWPAYMENTS_PRO_INVOICE_ID=
VITE_NOWPAYMENTS_DLC_INVOICE_ID=

# Optional override for the worker base URL (where the frontend calls
# /checkout and /verify-license). Defaults to https://lumi-pay.workers.dev
VITE_PAY_WORKER_URL=

# ----- Cloudflare Worker (server-side — NEVER expose to the browser) -----
# Get these from NOWPayments dashboard:
#   API key: Settings → Payments → API keys
#   IPN secret: Settings → Payments → Instant payment notifications → Set up IPN
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# Used by the worker to sign license keys. Generate with:
#   openssl rand -hex 32
LICENSE_SIGNING_SECRET=

# Resend (for sending license emails). Get a key at https://resend.com/api-keys
RESEND_API_KEY=
LICENSE_FROM_EMAIL=licenses@lumi.app
